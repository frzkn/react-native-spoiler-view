{
  "name": "react-native-spoiler-view",
  "version": "0.1.0",
  "description": "Telegram-style spoiler effect for React Native with native particle animations",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "types": "./lib/typescript/index.d.ts",
      "react-native": "./src/index.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "default": "./lib/module/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "android",
    "!android/build",
    "!android/.gradle",
    "!android/.cxx",
    "ios",
    "src",
    "lib",
    "react-native-spoiler-view.podspec",
    "react-native.config.js",
    "!**/__tests__"
  ],
  "scripts": {
    "build": "bob build",
    "check": "npm run typescript && npm test && npm run build",
    "test": "jest --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "typescript": "tsc --noEmit",
    "prepare": "bob build"
  },
  "keywords": [
    "react-native",
    "spoiler",
    "blur",
    "reveal",
    "telegram",
    "particles",
    "animation"
  ],
  "author": {
    "name": "Faraz Khan",
    "email": "farazrk001@gmail.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/frzkn/react-native-spoiler-view.git"
  },
  "bugs": {
    "url": "https://github.com/frzkn/react-native-spoiler-view/issues"
  },
  "homepage": "https://frzkn.github.io/react-native-spoiler-view",
  "peerDependencies": {
    "react": ">=18.0.0 <20",
    "react-native": ">=0.73.0 <0.87",
    "react-native-gesture-handler": ">=2.0.0 <4",
    "react-native-reanimated": ">=3.15.5 <5"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@react-native/babel-preset": "^0.73.21",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.0.0",
    "@types/react-test-renderer": "^18.3.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "react": "18.2.0",
    "react-native": "0.73.11",
    "react-native-builder-bob": "^0.23.0",
    "react-native-gesture-handler": "2.18.1",
    "react-native-reanimated": "3.15.5",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.0.0"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      "commonjs",
      "module",
      "typescript"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@11.6.2",
  "sideEffects": false
}
