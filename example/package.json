{
  "name": "react-native-spoiler-view-example",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android --port 8082",
    "bundle:android": "react-native bundle --platform android --dev false --entry-file index.js --bundle-output dist/android/index.android.bundle",
    "bundle:ios": "react-native bundle --platform ios --dev false --entry-file index.js --bundle-output dist/ios/main.jsbundle",
    "check": "tsc --noEmit && npm run lint && npm run bundle:ios && npm run bundle:android",
    "ios": "react-native run-ios --port 8082",
    "lint": "eslint .",
    "start": "react-native start --port 8082"
  },
  "dependencies": {
    "react": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "3.0.2",
    "react-native-reanimated": "4.5.1",
    "react-native-spoiler-view": "file:..",
    "react-native-worklets": "0.10.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.2.0",
    "@react-native-community/cli-platform-android": "20.2.0",
    "@react-native-community/cli-platform-ios": "20.2.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/eslint-config": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@react-native/typescript-config": "0.86.0",
    "@types/react": "^19.2.0",
    "eslint": "^8.19.0",
    "prettier": "2.8.8",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.11.0"
  }
}
